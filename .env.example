# Azure AD app registration for the Beak Teams connector.
# Copy to .env and fill in real values (see teams-app/manifest.json botId).
# Do NOT commit the resulting .env — it is gitignored.

export BEAK_CLIENT_ID=00000000-0000-0000-0000-000000000000
export BEAK_CLIENT_SECRET=your-client-secret-here
export BEAK_TENANT_ID=00000000-0000-0000-0000-000000000000
